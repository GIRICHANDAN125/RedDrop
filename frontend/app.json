{
  "expo": {
    "name": "Red Drop AI",
    "slug": "reddropai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.reddropai.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Red Drop AI needs your location to find nearby donors.",
        "NSLocationAlwaysUsageDescription": "Red Drop AI uses location to alert nearby donors in emergencies.",
        "NSCameraUsageDescription": "Upload medical reports and profile photos.",
        "NSPhotoLibraryUsageDescription": "Select medical reports and photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#E63946"
      },
      "package": "com.reddropai.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
      }
    },
    "plugins": [
      "expo-location",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/notification-icon.png",
          "color": "#E63946"
        }
      ]
    ],
    "scheme": "reddropai",
    "extra": {
      "eas": { "projectId": "your-eas-project-id" }
    }
  }
}
